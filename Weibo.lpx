#!name=微博去广告
#!desc=微博去广告
#!author=@ddgksf2013,@zmqcherish
#!UpdateTime=2025-09-16
#!Version=V2.0.114

[Rule]
DOMAIN,sdkapp.uve.weibo.com,DIRECT
DOMAIN,adstrategy.biz.weibo.com,REJECT
DOMAIN-SUFFIX,api.touch-moblie.com,REJECT

[Rewrite]
^https?:\/\/api\.weibo\.cn\/\d\/ug\/checkin\/stream response-body-json-jq '.items |= map(select(.category != "card"))'
^https?:\/\/api\.weibo\.cn\/\d\/statuses\/container_positive reject-200
^https?:\/\/api\.weibo\.cn\/\d\/push\/info reject-200
^https?:\/\/api\.weibo\.cn\/.*account\/recommend_interesttags reject-dict
^https?:\/\/api\.weibo\.cn\/.*\/media_homelist reject-200
^https?:\/\/api\.weibo\.cn\/.*finder\/searchbarchange reject-200
^https?:\/\/api\.weibo\.cn\/\d\/ad\/preload reject-dict
^https?:\/\/api\.weibo\.cn\/\d\/profile\/recommend_popuser reject-dict
^https?:\/\/boot.*weibo\.com\/v\d\/ad\/realtime reject-200
^https?:\/\/api\.weibo\.cn\/.*discovery_home_bottom_getdotinfo reject-dict
^https?:\/\/m?api\.weibo\.c(n|om)\/\d/push/daily reject-dict
^https?:\/\/(preload-click|preload-impression)\.uve\.weibo\.com\/(interface\/wbpullad\/wbpullad_click\.php|wbapplua\/get_wbpullad_log\.lua) reject
^https?:\/\/sdkapp\.uve\.weibo\.com\/interface\/sdk\/sdkconfig\.php reject
^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/hot\/hours_spotlight reject-dict
^https?:\/\/api\.weibo\.cn\/\d\/cardlist\?v_f=.*Weibo_intl reject-dict
^https?:\/\/weibointl\.api\.weibo\.c(n|om)\/portal\.php\?a=hot_search_users reject-dict
^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/ad\/weibointl\? reject-dict

[Script]
http-response ^https?:\/\/api\.weibo\.cn\/\d\/statuses\/container_detail script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, timeout=60, tag=weibo_json
http-response ^https?:\/\/api\.weibo\.cn\/\d\/groups\/allgroups\/v\d script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, timeout=60, tag=weibo_json
http-response ^https?:\/\/boot.*weibo\.com\/v\d\/ad\/preload script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, timeout=60, tag=weibo_json
http-response ^https?:\/\/api\.weibo\.cn\/\d\/\w{5}\/(statuses_unread_hot_timeline|timeline) script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, timeout=60, tag=weibo_json
http-response ^https?:\/\/api\.weibo\.cn\/\d\/video\/tiny_stream_mid_detail script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, timeout=60, tag=weibo_json
http-response ^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/\w{5}\/cardlist script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, timeout=60, tag=weibo_json
http-response ^https://api.weibo.cn/2/!/client/light_skin script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, timeout=60, tag=weibo_json
http-response ^https://new.vip.weibo.cn/littleskin/preview script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, timeout=60, tag=weibo_json
http-response ^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/(searchall|page\?|0flowpage) script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, timeout=60, tag=weibo_json
http-response ^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/statuses/(unread_)?friends(/|_)timeline script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, timeout=60, tag=weibo_json
http-response ^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/groups/timeline script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, timeout=60, tag=weibo_json
http-response ^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/statuses/(container_timeline|unread_hot_timeline|extend|video_mixtimeline|unread_topic_timeline) script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, timeout=60, tag=weibo_json
http-response ^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/profile/(me|container_timeline) script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, timeout=60, tag=weibo_json
http-response ^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/video/(community_tab|remind_info|tiny_stream_video_list) script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, timeout=60, tag=weibo_json
http-response ^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/search/(finder|container_timeline|container_discover) script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, timeout=60, tag=weibo_json
http-response ^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/(checkin/show|\!/live/media_homelist|container/get_item) script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, timeout=60, tag=weibo_json
http-response ^https?:\/\/m?api\.weibo\.c(n|om)\/\d\/cardlist script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, timeout=60, tag=weibo_json
http-response ^https?:\/\/weibointl\.api\.weibo\.cn\/portal\.php\?a=open_app script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, timeout=60, tag=weibo_json
http-response ^https?:\/\/weibointl\.api\.weibo\.c(n|om)\/portal\.php.*a=get_searching_info script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_search_info.json, requires-body=true, timeout=60, tag=weibo_search_info
http-response ^https?:\/\/weibointl\.api\.weibo\.c(n|om)\/portal\.php.*feed&a=search_topic script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_search_topic.json, requires-body=true, timeout=60, tag=weibo_search_topic
http-response ^https?:\/\/weibointl\.api\.weibo\.c(n|om)\/portal\.php.*get_coopen_ads script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, timeout=60, tag=weibo_json
http-response ^https?://(sdk|wb)app\.uve\.weibo\.com(/interface/sdk/sdkad.php|/wbapplua/wbpullad.lua) script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, timeout=60, tag=weibo_json
http-response ^https?://(sdk|wb)app\.uve\.weibo\.com(/interface/sdk/sdkad.php|/wbapplua/wbpullad.lua) script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, timeout=60, tag=weibo_json
http-response ^https?:\/\/weibointl\.api\.weibo\.cn\/portal\.php\?a=user_center script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, timeout=60, tag=weibo_json
http-response ^https?:\/\/weibointl\.api\.weibo\.cn\/portal\.php\?a=search_topic script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/weibo_json.js, requires-body=true, timeout=60, tag=weibo_json

[MITM]
hostname = api.weibo.*, *.api.weibo.*, mapi.weibo.*, *.uve.weibo.com, new.vip.weibo.cn, boot.biz.weibo.com
